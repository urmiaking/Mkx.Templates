@attribute [Route(ClientRoutes.Tests.Index)]
@attribute [Authorize]
@inherits AppComponentBase

<PageTitle>تست‌ها</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge">
    <MudBreadcrumbs Class="px-0" Items="_breadcrumbs" MaxItems="2">
        <SeparatorTemplate>
            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Size="Size.Small" />
        </SeparatorTemplate>
    </MudBreadcrumbs>

    <MudText Typo="Typo.h4" Class="mb-4">مدیریت تست‌ها</MudText>

    <MudTable Items="_tests" Hover="true" Loading="IsBusy" LoadingProgressColor="Color.Info" Elevation="2">
        <HeaderContent>
            <MudTh>شناسه</MudTh>
            <MudTh>نام</MudTh>
            <MudTh>توضیحات</MudTh>
        </HeaderContent>
        <RowTemplate Context="test">
            <MudTd DataLabel="شناسه">@test.Id</MudTd>
            <MudTd DataLabel="نام">@test.Name</MudTd>
            <MudTd DataLabel="توضیحات">@test.Description</MudTd>
        </RowTemplate>
    </MudTable>

</MudContainer>

@code {
    private List<GetTestResponse> _tests = [];

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("صفحه اصلی", href: ClientRoutes.Home.Index, icon: Icons.Material.Filled.Home),
        new("تست ها", href: ClientRoutes.Tests.Index, icon: Icons.Material.Filled.CheckCircle)
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadTests();
        await base.OnInitializedAsync();
    }

    private async Task LoadTests()
    {
        var result = await SendRequestAsync<ITestService, List<GetTestResponse>>(
            action: (s, ct) => s.GetAllAsync(ct));

        if (result != null)
        {
            _tests = result;
        }
    }
}
