@inherits AppComponentBase

<EditForm Model="_model" OnValidSubmit="Submit">
    <DataAnnotationsValidator />

    <MudDialog>
        <DialogContent>
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Password"
                                  For="@(() => _model.Password)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Key"
                                  InputType="InputType.Password"
                                  Label="@_model.GetDisplayName(() => _model.Password)"
                                  Margin="Margin.Dense"
                                  dir="ltr"
                                  Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.NewPassword"
                                  For="@(() => _model.NewPassword)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.VpnKey"
                                  InputType="InputType.Password"
                                  Label="@_model.GetDisplayName(() => _model.NewPassword)"
                                  Margin="Margin.Dense"
                                  dir="ltr"
                                  Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.ConfirmPassword"
                                  For="@(() => _model.ConfirmPassword)"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Repeat"
                                  InputType="InputType.Password"
                                  Label="@_model.GetDisplayName(() => _model.ConfirmPassword)"
                                  Margin="Margin.Dense"
                                  dir="ltr"
                                  Variant="Variant.Outlined"/>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Error"
                       OnClick="Close"
                       StartIcon="@Icons.Material.Filled.Close"
                       Variant="Variant.Filled">انصراف</MudButton>

            <MudButton Class="m-2"
                       Color="Color.Primary"
                       Disabled="@IsBusy"
                       ButtonType="ButtonType.Submit"
                       StartIcon="@Icons.Material.Filled.Save"
                       Variant="Variant.Filled">
                @if (IsBusy)
                {
                    <MudProgressCircular Class="ms-n1"
                                         Size="Size.Small"
                                         Indeterminate="true"/>
                    <MudText Class="ms-2">
                        در حال ذخیره
                    </MudText>
                }
                else
                {
                    <MudText>ذخیره</MudText>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>