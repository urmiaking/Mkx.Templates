@inherits MudComponentBase

@if (Locked)
{
    <MudPaper Class="pa-4 py-5 action-card locked"
              Width="100%"
              Elevation="0">

        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center"
                  Spacing="2">

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                <MudIcon Icon="@StartIcon"
                         Size="Size.Large"
                         Color="@Color" />

                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6">@Title</MudText>
                    <MudText Typo="Typo.caption">@Description</MudText>
                </MudStack>
            </MudStack>

            <MudIcon Icon="@Icons.Material.Filled.Lock"
                     Color="Color.Error" Size="Size.Large" />
        </MudStack>
    </MudPaper>
}
else
{
    if (!string.IsNullOrEmpty(Href))
    {
        <MudLink Href="@Href" Underline="Underline.None" Style="color: inherit; width: 100%;">
            <MudPaper Class="pa-4 py-5 action-card"
                      Width="100%"
                      Elevation="0">

                <MudStack Row="true"
                          Justify="Justify.SpaceBetween"
                          AlignItems="AlignItems.Center"
                          Spacing="2">

                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@StartIcon"
                                 Size="Size.Large"
                                 Color="@Color" />

                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6">@Title</MudText>
                            <MudText Typo="Typo.caption">@Description</MudText>
                        </MudStack>
                    </MudStack>

                    <MudIcon Icon="@Icons.Material.Filled.ArrowBackIos"
                             Color="@Color" />
                </MudStack>
            </MudPaper>
        </MudLink>
    }
    else
    {
        <MudPaper Class="pa-4 py-5 action-card cursor-pointer"
                  Width="100%"
                  @onclick="OnClick"
                  Elevation="0">

            <MudStack Row="true"
                      Justify="Justify.SpaceBetween"
                      AlignItems="AlignItems.Center"
                      Spacing="2">

                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                    <MudIcon Icon="@StartIcon"
                             Size="Size.Large"
                             Color="@Color" />

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h6">@Title</MudText>
                        <MudText Typo="Typo.caption">@Description</MudText>
                    </MudStack>
                </MudStack>

                <MudIcon Icon="@Icons.Material.Filled.ArrowBackIos"
                         Color="@Color" />
            </MudStack>
        </MudPaper>
    }
}

@code {
    [Parameter] public string Title { get; set; } = "Title";
    [Parameter] public string Description { get; set; } = "Description";
    [Parameter] public string StartIcon { get; set; } = Icons.Material.Filled.Settings;
    [Parameter] public string? Href { get; set; }
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public bool Locked { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
}
